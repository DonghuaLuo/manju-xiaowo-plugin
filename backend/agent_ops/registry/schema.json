{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manju.local/schemas/agent-script-record.schema.json",
  "title": "Manju Agent Script Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "script_id",
    "version",
    "status",
    "owner",
    "created_at",
    "updated_at",
    "summary",
    "working_directory",
    "entrypoints",
    "source_files",
    "evidence",
    "validation_commands",
    "tests",
    "failure_examples",
    "known_failures",
    "rollback",
    "notes"
  ],
  "properties": {
    "script_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "type": "string", "enum": ["default", "experimental", "deprecated"] },
    "owner": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "summary": { "type": "string", "minLength": 1 },
    "working_directory": { "type": "string", "minLength": 1 },
    "entrypoints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "source_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validation_commands": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "tests": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "failure_examples": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "known_failures": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rollback": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "notes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "repair_write_allowlist": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
